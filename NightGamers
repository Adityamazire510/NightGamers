/* FEATURED */
.fsec{padding:0 5vw 5rem;position:relative;z-index:1}
.fcard{background:var(--surf);border:1px solid var(--br);display:grid;grid-template-columns:1fr 1fr;overflow:hidden;position:relative;min-height:360px}
