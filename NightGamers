.fdesc{font-size:.95rem;color:var(--tx2);line-height:1.7;margin-bottom:1.5rem;max-width:380px}
.fmeta{display:flex;gap:1.5rem;margin-bottom:2rem;flex-wrap:wrap}
.fm{display:flex;flex-direction:column;gap:2px}
.fml{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase}
.fmv{font-size:.9rem;font-weight:600;color:var(--tx)}
.fpr{font-family:'Bebas Neue',sans-serif;font-size:3rem;color:var(--a2);letter-spacing:3px;line-height:1;margin-bottom:1.5rem;text-shadow:0 0 20px rgba(255,45,120,.4)}
.fbdg{display:inline-block;background:var(--a2);color:#fff;font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:3px;padding:4px 12px;margin-bottom:1.2rem;text-transform:uppercase}
.fimg{overflow:hidden;position:relative}
.fimg img{width:100%;height:100%;object-fit:cover;display:block}
/* HOW IT WORKS */
.how-s{background:var(--bg2);border-top:1px solid var(--br);border-bottom:1px solid var(--br)}
.stp-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem}
.stp{text-align:center;padding:2rem 1rem;position:relative;animation:fup .6s ease both}
.stp::after{content:'→';position:absolute;right:-1rem;top:50%;transform:translateY(-50%);color:var(--br);font-size:1.5rem}
.stp:last-child::after{display:none}
.stp-n{font-family:'Bebas Neue',sans-serif;font-size:4rem;color:rgba(0,229,255,.08);line-height:1;margin-bottom:-.5rem}
.stp-i{font-size:2.5rem;margin-bottom:1rem;display:block}
.stp-t{font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:2px;margin-bottom:.5rem;color:var(--a)}
.stp p{font-size:.9rem;color:var(--tx2);line-height:1.6}
/* CART */
.covl{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:999;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(4px)}
.covl.open{opacity:1;pointer-events:all}
.cart-d{position:fixed;top:0;right:-440px;width:min(440px,100vw);height:100vh;background:var(--surf);border-left:1px solid var(--br);z-index:1000;transition:right .35s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:-20px 0 60px rgba(0,0,0,.5)}
.cart-d.open{right:0}
.cart-h{display:flex;align-items:center;justify-content:space-between;padding:1.5rem;border-bottom:1px solid var(--br)}
.cart-h h3{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:3px;color:var(--a)}
.ccls{background:none;border:1px solid var(--br);color:var(--tx2);cursor:pointer;font-size:1.2rem;width:34px;height:34px;display:flex;align-items:center;justify-content:center;transition:all .2s}
