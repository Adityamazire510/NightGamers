.cart-items{flex:1;overflow-y:auto;padding:1rem;scrollbar-width:thin;scrollbar-color:var(--br) transparent}
.ci{display:flex;gap:1rem;padding:1rem 0;border-bottom:1px solid var(--br);animation:fup .3s ease}
