}

let revNotifTimer;
function startReviewNotifLoop() {
  const notif = document.getElementById('rev-notif');
  if (!notif) return;
  let idx = 0;
  const pool = [...REVIEW_DATA].sort(() => Math.random() - 0.5);

  function showNext() {
    const r = pool[idx % pool.length];
    idx++;
    document.getElementById('rev-notif-av').style.background = r.color;
    document.getElementById('rev-notif-av').textContent = r.initials;
    document.getElementById('rev-notif-title').textContent = 'New Review · ' + r.game;
    document.getElementById('rev-notif-text').textContent = r.name + ' just left a ' + r.rating + '-star review';
    notif.classList.add('show');
    setTimeout(() => notif.classList.remove('show'), 3800);
    revNotifTimer = setTimeout(showNext, 8000 + Math.random() * 6000);
  }
  revNotifTimer = setTimeout(showNext, 5000);
}

