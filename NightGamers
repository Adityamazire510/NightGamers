<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NightGamers — Physical PC Game Store</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#050810;--bg2:#080d1a;--surf:#0d1526;--surf2:#111d35;
  --a:#00e5ff;--a2:#ff2d78;--a3:#7b2fff;
  --tx:#e8f0ff;--tx2:#8a99bb;
  --br:rgba(0,229,255,0.12);
  --glow:0 0 30px rgba(0,229,255,0.25);
  --glow2:0 0 30px rgba(255,45,120,0.25);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--tx);font-family:'Rajdhani',sans-serif;font-size:16px;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,229,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.025) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0}
nav{position:sticky;top:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 5vw;height:64px;background:rgba(5,8,16,.93);backdrop-filter:blur(20px);border-bottom:1px solid var(--br)}
.logo{display:inline-flex;align-items:center;gap:10px;cursor:pointer;text-decoration:none;flex-shrink:0}
.logo-mark{width:36px;height:36px;flex-shrink:0;filter:drop-shadow(0 0 8px rgba(139,92,246,.8));transition:filter .3s,transform .3s}
.logo:hover .logo-mark{filter:drop-shadow(0 0 14px rgba(139,92,246,1)) drop-shadow(0 0 6px rgba(0,229,255,.6));transform:rotate(-8deg) scale(1.1)}
.logo:hover .logo-main{animation:logoglitch .4s steps(2) both}
@keyframes logoglitch{0%{text-shadow:2px 0 #ff2d78,-2px 0 #00e5ff}25%{text-shadow:-2px 0 #ff2d78,2px 0 #00e5ff}50%{text-shadow:2px 0 #a78bfa,-2px 0 #00ff88}75%{text-shadow:-1px 0 #ff2d78,1px 0 #00e5ff}100%{text-shadow:none}}
.logo-text{display:flex;flex-direction:column;line-height:1}
.logo-main{font-family:'Bebas Neue',sans-serif;font-size:1.45rem;letter-spacing:5px;background:linear-gradient(90deg,#a78bfa 0%,#00e5ff 60%,#ff2d78 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;text-shadow:none}
.logo-sub{font-family:'Share Tech Mono',monospace;font-size:.42rem;letter-spacing:4px;color:rgba(139,92,246,.7);text-transform:uppercase;margin-top:1px}
nav ul{display:flex;gap:2rem;list-style:none}
nav ul a{font-family:'Share Tech Mono',monospace;font-size:.78rem;letter-spacing:2px;color:var(--tx2);text-decoration:none;text-transform:uppercase;transition:color .2s;cursor:pointer}
nav ul a:hover,nav ul a.active{color:var(--a)}
.nav-r{display:flex;gap:1rem;align-items:center}
.cart-btn{background:transparent;border:1px solid var(--a);color:var(--a);font-family:'Share Tech Mono',monospace;font-size:.75rem;letter-spacing:2px;padding:8px 18px;cursor:pointer;text-transform:uppercase;transition:all .2s;position:relative}
.cart-btn:hover{background:var(--a);color:var(--bg);box-shadow:var(--glow)}
.cn{position:absolute;top:-8px;right:-8px;background:var(--a2);color:#fff;font-size:.62rem;width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center}
.hburg{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
.hburg span{display:block;width:24px;height:2px;background:var(--a)}
.mobn{display:none;position:fixed;top:64px;left:0;right:0;background:rgba(5,8,16,.98);backdrop-filter:blur(20px);border-bottom:1px solid var(--br);padding:1.5rem 5vw;z-index:199;flex-direction:column;gap:1.5rem}
.mobn.open{display:flex}
.mobn a{font-family:'Share Tech Mono',monospace;font-size:.85rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase;padding:8px 0;border-bottom:1px solid var(--br);cursor:pointer}
/* PAGE TRANSITIONS */
#app{position:relative}
.page{display:none;opacity:0;pointer-events:none}
.page.active{display:block;opacity:1;pointer-events:all}
.page.pin-r{display:block;animation:pinR .55s cubic-bezier(.22,1,.36,1) both}
.page.pin-l{display:block;animation:pinL .55s cubic-bezier(.22,1,.36,1) both}
.page.pout-l{display:block;animation:poutL .35s cubic-bezier(.55,0,1,.45) both;pointer-events:none}
.page.pout-r{display:block;animation:poutR .35s cubic-bezier(.55,0,1,.45) both;pointer-events:none}
@keyframes pinR{from{opacity:0;transform:translateX(70px) scale(.97)}to{opacity:1;transform:none}}
@keyframes pinL{from{opacity:0;transform:translateX(-70px) scale(.97)}to{opacity:1;transform:none}}
@keyframes poutL{from{opacity:1;transform:none}to{opacity:0;transform:translateX(-60px) scale(.96)}}
@keyframes poutR{from{opacity:1;transform:none}to{opacity:0;transform:translateX(60px) scale(.96)}}
#tOvl{position:fixed;inset:0;z-index:500;pointer-events:none;opacity:0;transform:scaleX(0);transform-origin:left}
#tOvl.wi{animation:wi .28s cubic-bezier(.76,0,.24,1) forwards}
#tOvl.wo{animation:wo .32s cubic-bezier(.76,0,.24,1) forwards}
@keyframes wi{0%{opacity:.18;transform:scaleX(0);transform-origin:left}100%{opacity:.18;transform:scaleX(1);transform-origin:left}}
@keyframes wo{0%{opacity:.18;transform:scaleX(1);transform-origin:right}100%{opacity:0;transform:scaleX(0);transform-origin:right}}
/* HERO */
.hero{position:relative;min-height:88vh;display:flex;align-items:center;padding:6rem 5vw 4rem;overflow:hidden}
.hero-bg{position:absolute;inset:0;background:radial-gradient(ellipse 60% 60% at 70% 50%,rgba(123,47,255,.18) 0%,transparent 70%),radial-gradient(ellipse 40% 40% at 20% 80%,rgba(0,229,255,.1) 0%,transparent 60%);pointer-events:none}
.hero-c{position:relative;z-index:1;max-width:560px;animation:fup .8s ease both}
.htag{font-family:'Share Tech Mono',monospace;font-size:.72rem;letter-spacing:4px;color:var(--a2);text-transform:uppercase;margin-bottom:1rem;display:flex;align-items:center;gap:8px}
.htag::before{content:'';width:28px;height:1px;background:var(--a2);display:inline-block}
.hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,8vw,6.5rem);line-height:.92;letter-spacing:2px;margin-bottom:1.5rem}
.hero h1 .hl{color:var(--a);text-shadow:0 0 40px var(--a)}
.hero p{font-size:1.1rem;color:var(--tx2);line-height:1.7;margin-bottom:2.5rem;max-width:420px}
.hcta{display:flex;gap:1rem;flex-wrap:wrap}
.bp{background:var(--a);color:var(--bg);font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:3px;padding:14px 36px;border:none;cursor:pointer;text-transform:uppercase;transition:all .2s;display:inline-block;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px))}
.bp:hover{box-shadow:var(--glow);transform:translateY(-2px)}
.bo{background:transparent;color:var(--tx);font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:3px;padding:13px 36px;border:1px solid rgba(255,255,255,.2);cursor:pointer;text-transform:uppercase;transition:all .2s;display:inline-block;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px))}
.bo:hover{border-color:var(--a);color:var(--a)}
.hero-vis{position:absolute;right:0;top:50%;transform:translateY(-50%);width:50%;max-width:600px;pointer-events:none;display:flex;align-items:center;justify-content:center;animation:fin 1.2s ease both .3s}
.cd{width:min(380px,44vw);height:min(380px,44vw);border-radius:50%;background:conic-gradient(from 0deg,#1a0a2e,#0d1526,#0a1a2e,#1a0a2e,#000820,#1a0a2e,#0d1526,#0a1a2e);position:relative;animation:spin 8s linear infinite;box-shadow:0 0 60px rgba(0,229,255,.2),0 0 120px rgba(123,47,255,.1),inset 0 0 40px rgba(0,0,0,.5)}
.cd::before{content:'';position:absolute;inset:0;border-radius:50%;background:conic-gradient(from 0deg,rgba(0,229,255,.4),rgba(255,45,120,.3),rgba(123,47,255,.4),rgba(0,229,255,.2),rgba(255,200,0,.2),rgba(0,229,255,.4));mix-blend-mode:screen}
.cd::after{content:'';position:absolute;inset:18%;border-radius:50%;background:var(--bg)}
.cd-c{position:absolute;width:14%;height:14%;border-radius:50%;background:var(--a);z-index:2;box-shadow:0 0 20px var(--a);top:50%;left:50%;transform:translate(-50%,-50%)}
.cd-r{position:absolute;border-radius:50%;border:1px solid rgba(0,229,255,.15);top:50%;left:50%;transform:translate(-50%,-50%)}
.cd-r:nth-child(1){width:50%;height:50%}.cd-r:nth-child(2){width:30%;height:30%}.cd-r:nth-child(3){width:70%;height:70%}
/* STATS */
.sbar{position:relative;z-index:1;display:flex;padding:1.5rem 5vw;border-top:1px solid var(--br);border-bottom:1px solid var(--br);background:rgba(13,21,38,.5);overflow-x:auto}
.si{flex:1;min-width:90px;text-align:center;padding:1rem;border-right:1px solid var(--br)}.si:last-child{border-right:none}
.sn{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--a);line-height:1}
.slb{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase;margin-top:4px}
/* SECTION */
section{position:relative;z-index:1;padding:5rem 5vw}
.sh{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:3rem;gap:1rem;flex-wrap:wrap}
.st{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,4vw,3rem);letter-spacing:3px;line-height:1}
.st span{color:var(--a);text-shadow:0 0 20px rgba(0,229,255,.4)}
.ss{font-family:'Share Tech Mono',monospace;font-size:.7rem;letter-spacing:3px;color:var(--tx2);text-transform:uppercase;margin-bottom:6px}
/* GENRE CARDS */
.gg{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(200px,100%),1fr));gap:1.2rem}
.gc{background:var(--surf);border:1px solid var(--br);padding:2rem 1.5rem;cursor:pointer;transition:transform .3s,box-shadow .3s,border-color .3s;position:relative;overflow:hidden;animation:fup .5s ease both}
.gc::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .3s}
.gc:hover{transform:translateY(-6px)}.gc:hover::before{opacity:1}.gc:hover .garr{transform:translateX(4px);opacity:1}.gc:hover .gico{transform:scale(1.1)}
.gc-fps{--gc:#ff2d78}.gc-fps::before{background:radial-gradient(circle at 80% 20%,rgba(255,45,120,.12) 0%,transparent 70%)}.gc-fps:hover{border-color:rgba(255,45,120,.4);box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 0 1px rgba(255,45,120,.2)}
.gc-rpg{--gc:#7b2fff}.gc-rpg::before{background:radial-gradient(circle at 80% 20%,rgba(123,47,255,.12) 0%,transparent 70%)}.gc-rpg:hover{border-color:rgba(123,47,255,.4);box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 0 1px rgba(123,47,255,.2)}
.gc-str{--gc:#00e5ff}.gc-str::before{background:radial-gradient(circle at 80% 20%,rgba(0,229,255,.12) 0%,transparent 70%)}.gc-str:hover{border-color:rgba(0,229,255,.4);box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 0 1px rgba(0,229,255,.2)}
.gc-spt{--gc:#00ff88}.gc-spt::before{background:radial-gradient(circle at 80% 20%,rgba(0,255,136,.12) 0%,transparent 70%)}.gc-spt:hover{border-color:rgba(0,255,136,.4);box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 0 1px rgba(0,255,136,.2)}
.gc-sim{--gc:#ffb800}.gc-sim::before{background:radial-gradient(circle at 80% 20%,rgba(255,184,0,.12) 0%,transparent 70%)}.gc-sim:hover{border-color:rgba(255,184,0,.4);box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 0 1px rgba(255,184,0,.2)}
.gc-adv{--gc:#ff6b35}.gc-adv::before{background:radial-gradient(circle at 80% 20%,rgba(255,107,53,.12) 0%,transparent 70%)}.gc-adv:hover{border-color:rgba(255,107,53,.4);box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 0 1px rgba(255,107,53,.2)}
.gc-rac{--gc:#e040fb}.gc-rac::before{background:radial-gradient(circle at 80% 20%,rgba(224,64,251,.12) 0%,transparent 70%)}.gc-rac:hover{border-color:rgba(224,64,251,.4);box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 0 1px rgba(224,64,251,.2)}
.gc-hor{--gc:#ff1744}.gc-hor::before{background:radial-gradient(circle at 80% 20%,rgba(255,23,68,.12) 0%,transparent 70%)}.gc-hor:hover{border-color:rgba(255,23,68,.4);box-shadow:0 16px 40px rgba(0,0,0,.4),0 0 0 1px rgba(255,23,68,.2)}
.gico{font-size:2.8rem;display:block;margin-bottom:1rem;transition:transform .3s}
.gname{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:3px;margin-bottom:4px;color:var(--gc,var(--a))}
.gcnt{font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase;margin-bottom:.75rem}
.gdesc{font-size:.88rem;color:var(--tx2);line-height:1.5;margin-bottom:1rem}
.garr{font-family:'Share Tech Mono',monospace;font-size:.7rem;letter-spacing:2px;color:var(--gc,var(--a));opacity:.6;transition:transform .25s,opacity .25s}
/* GAME CARDS */
.gmg{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(240px,100%),1fr));gap:1.5rem}
.gmc{background:var(--surf);border:1px solid var(--br);position:relative;cursor:pointer;transition:transform .3s,box-shadow .3s;overflow:hidden;animation:fup .5s ease both}
.gmc:hover{transform:translateY(-6px);box-shadow:0 20px 40px rgba(0,0,0,.4),0 0 0 1px rgba(0,229,255,.2)}.gmc:hover .cov{opacity:1}.gmc:hover .cw img{transform:scale(1.06)}
.cw{aspect-ratio:3/4;overflow:hidden;position:relative;background:#020408}
.cw img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s}
.img-err{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.5rem;font-family:'Bebas Neue',sans-serif;letter-spacing:2px;font-size:.9rem;color:rgba(255,255,255,.4);text-align:center;padding:.5rem}
.img-err span{font-size:2.5rem}
.cov{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.92) 0%,transparent 55%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:1rem;gap:.5rem;flex-direction:column}
.qadd{width:100%;background:var(--a);color:var(--bg);font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:3px;padding:10px;border:none;cursor:pointer;text-transform:uppercase;transition:background .2s}
.qadd:hover{background:var(--a2)}
.infob{width:100%;background:transparent;border:1px solid rgba(255,255,255,.25);color:#fff;font-family:'Share Tech Mono',monospace;font-size:.68rem;letter-spacing:2px;padding:8px;cursor:pointer;text-transform:uppercase;transition:all .2s}
.infob:hover{border-color:var(--a);color:var(--a)}
.bdg{position:absolute;top:12px;left:12px;font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:2px;padding:3px 10px;text-transform:uppercase;z-index:2}
.bdg-new{background:var(--a2);color:#fff}.bdg-sale{background:#ffb800;color:#000}.bdg-hot{background:var(--a3);color:#fff}
.cb{padding:1rem}
.cgen{font-family:'Share Tech Mono',monospace;font-size:.62rem;letter-spacing:2px;color:var(--a);text-transform:uppercase;margin-bottom:4px}
.ctit{font-family:'Bebas Neue',sans-serif;font-size:1.25rem;letter-spacing:2px;margin-bottom:4px;line-height:1.1}
.cdev{font-size:.8rem;color:var(--tx2);margin-bottom:.75rem}
.crat{display:flex;align-items:center;gap:6px;margin-bottom:.75rem}
.cstars{color:#ffb800;font-size:.8rem}
.crn{font-family:'Share Tech Mono',monospace;font-size:.7rem;color:var(--tx2)}
.cpr{display:flex;align-items:center;justify-content:space-between;gap:.5rem}
.cprice{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;color:var(--a);letter-spacing:2px}
.corig{font-family:'Share Tech Mono',monospace;font-size:.75rem;color:var(--tx2);text-decoration:line-through}
.addc{background:transparent;border:1px solid var(--a);color:var(--a);font-family:'Bebas Neue',sans-serif;font-size:.9rem;letter-spacing:2px;padding:8px 16px;cursor:pointer;transition:all .2s;text-transform:uppercase}
.addc:hover,.addc.added{background:var(--a);color:var(--bg);box-shadow:var(--glow)}
/* GENRE PAGE HERO */
.ghero{position:relative;padding:4rem 5vw 3rem;overflow:hidden;border-bottom:1px solid var(--br)}
.ghero-bg{position:absolute;inset:0;pointer-events:none}
.ghero-c{position:relative;z-index:1}
.back-b{display:inline-flex;align-items:center;gap:8px;background:transparent;border:1px solid var(--br);color:var(--tx2);font-family:'Share Tech Mono',monospace;font-size:.72rem;letter-spacing:2px;padding:8px 18px;cursor:pointer;text-transform:uppercase;transition:all .2s;margin-bottom:2rem}
.back-b:hover{border-color:var(--a);color:var(--a)}
.ghtit{font-family:'Bebas Neue',sans-serif;font-size:clamp(3rem,8vw,6rem);letter-spacing:3px;line-height:.9;margin-bottom:1rem}
.ghdesc{font-size:1rem;color:var(--tx2);line-height:1.7;max-width:560px;margin-bottom:2rem}
.ghstats{display:flex;gap:2rem;flex-wrap:wrap}
.ghsn{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:2px;line-height:1}
.ghsl{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase}
/* FILTER BAR */
.fbar{position:relative;z-index:1;display:flex;gap:.6rem;padding:1.5rem 5vw;border-bottom:1px solid var(--br);background:rgba(13,21,38,.3);flex-wrap:wrap;align-items:center}
.flbl{font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase;margin-right:.5rem}
.fb{background:transparent;border:1px solid var(--br);color:var(--tx2);font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:2px;padding:6px 14px;cursor:pointer;text-transform:uppercase;transition:all .2s}
.fb:hover,.fb.active{border-color:var(--a);color:var(--a);background:rgba(0,229,255,.05)}
/* GAME DETAIL MODAL */
.movl{position:fixed;inset:0;background:rgba(0,0,0,.88);z-index:800;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(10px)}
.movl.open{opacity:1;pointer-events:all}
.modal{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.92);width:min(940px,95vw);max-height:90vh;background:var(--surf);border:1px solid var(--br);z-index:801;overflow-y:auto;transition:transform .35s cubic-bezier(.22,1,.36,1),opacity .35s;opacity:0;scrollbar-width:thin;scrollbar-color:var(--br) transparent}
.movl.open .modal{transform:translate(-50%,-50%) scale(1);opacity:1}
.mi{display:grid;grid-template-columns:300px 1fr}
.mcover{width:100%;height:100%;object-fit:cover;display:block;background:#020408;min-height:420px}
.mcw{position:relative;overflow:hidden;background:#020408}
.mcls{position:absolute;top:12px;right:12px;background:rgba(0,0,0,.7);border:1px solid var(--br);color:var(--tx2);cursor:pointer;font-size:1.1rem;width:36px;height:36px;display:flex;align-items:center;justify-content:center;transition:all .2s;z-index:2}
.mcls:hover{border-color:var(--a2);color:var(--a2)}
.mbody{padding:2rem;overflow-y:auto}
.mtag{font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:3px;color:var(--a);text-transform:uppercase;margin-bottom:.75rem}
.mtit{font-family:'Bebas Neue',sans-serif;font-size:2.4rem;letter-spacing:3px;line-height:1;margin-bottom:.25rem}
.mdev{font-size:.9rem;color:var(--tx2);margin-bottom:1rem}
.mrat{display:flex;align-items:center;gap:10px;margin-bottom:1.5rem}
.mstars{color:#ffb800;font-size:1rem;letter-spacing:2px}
.mrn{font-family:'Share Tech Mono',monospace;font-size:.75rem;color:var(--tx2)}
.mdesc{font-size:.95rem;color:var(--tx2);line-height:1.7;margin-bottom:1.5rem}
.mmgrid{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.5rem}
.mmi{background:var(--bg2);border:1px solid var(--br);padding:.75rem}
.mmil{font-family:'Share Tech Mono',monospace;font-size:.58rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase;margin-bottom:3px}
.mmiv{font-size:.92rem;font-weight:600;color:var(--tx)}
.mtags{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1.5rem}
.mtag2{background:var(--bg2);border:1px solid var(--br);font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:2px;padding:4px 10px;color:var(--tx2);text-transform:uppercase}
.mscrow{display:flex;gap:.5rem;margin-bottom:1.5rem;overflow-x:auto;scrollbar-width:thin;scrollbar-color:var(--br) transparent;padding-bottom:4px}
.msc{width:130px;height:74px;object-fit:cover;flex-shrink:0;border:1px solid var(--br);cursor:pointer;transition:border-color .2s;display:block;background:#020408}
.msc:hover{border-color:var(--a)}
