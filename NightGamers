.fi{padding:3rem;display:flex;flex-direction:column;justify-content:center;position:relative;z-index:1}
.ftit{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.5rem,5vw,4rem);letter-spacing:3px;line-height:.95;margin-bottom:1rem}
