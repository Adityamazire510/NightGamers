.ci-info{flex:1}
.ci-t{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;margin-bottom:4px}
.ci-g{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:2px;color:var(--a);text-transform:uppercase;margin-bottom:8px}
.ci-p{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:var(--a2);letter-spacing:2px}
.ri{background:none;border:none;color:var(--tx2);cursor:pointer;font-size:1rem;align-self:flex-start;padding:2px;transition:color .2s}
.ri:hover{color:var(--a2)}
.ce{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:1rem;color:var(--tx2)}
.ce-i{font-size:3rem;opacity:.3}
.ce p{font-family:'Share Tech Mono',monospace;font-size:.75rem;letter-spacing:2px}
.cart-f{padding:1.5rem;border-top:1px solid var(--br);background:var(--bg2)}
.ctr{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem}
.ctl{font-family:'Share Tech Mono',monospace;font-size:.75rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase}
.ctv{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:2px;color:var(--a)}
.chk{width:100%;background:var(--a2);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:4px;padding:16px;border:none;cursor:pointer;text-transform:uppercase;transition:all .2s;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px))}
.chk:hover{box-shadow:var(--glow2);transform:translateY(-1px)}
/* PAYMENT MODAL */
.pmovl{position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:1100;opacity:0;pointer-events:none;transition:opacity .3s;backdrop-filter:blur(12px)}
.pmovl.open{opacity:1;pointer-events:all}
.pmod{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%) scale(.92);width:min(580px,96vw);max-height:92vh;background:var(--surf);border:1px solid var(--br);z-index:1101;overflow-y:auto;transition:transform .4s cubic-bezier(.22,1,.36,1),opacity .4s;opacity:0;scrollbar-width:thin;scrollbar-color:var(--br) transparent;box-shadow:0 0 80px rgba(0,0,0,.7)}
.pmovl.open .pmod{transform:translate(-50%,-50%) scale(1);opacity:1}
.ph{padding:1.5rem;border-bottom:1px solid var(--br);display:flex;align-items:center;justify-content:space-between}
.ph h3{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:3px;color:var(--a)}
.pcls{background:none;border:1px solid var(--br);color:var(--tx2);cursor:pointer;font-size:1.1rem;width:34px;height:34px;display:flex;align-items:center;justify-content:center;transition:all .2s}
.pcls:hover{border-color:var(--a2);color:var(--a2)}
.pb{padding:1.5rem}
/* Payment progress steps */
.psteps{display:flex;align-items:center;margin-bottom:2rem}
.psi{flex:1;text-align:center;position:relative}
.psi::before{content:'';position:absolute;top:14px;left:calc(-50% + 14px);width:calc(100% - 28px);height:1px;background:var(--br)}
.psi:first-child::before{display:none}
.psin{width:28px;height:28px;border-radius:50%;border:2px solid var(--br);font-family:'Share Tech Mono',monospace;font-size:.65rem;display:flex;align-items:center;justify-content:center;margin:0 auto .4rem;color:var(--tx2);transition:all .3s;background:var(--surf)}
.psin.done{background:var(--a);border-color:var(--a);color:var(--bg)}
.psin.cur{border-color:var(--a);color:var(--a)}
.psil{font-family:'Share Tech Mono',monospace;font-size:.56rem;letter-spacing:1px;color:var(--tx2);text-transform:uppercase}
/* order summary in payment */
.osumm{background:var(--bg2);border:1px solid var(--br);padding:1rem;margin-bottom:1.5rem}
.ostit{font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:3px;color:var(--a);text-transform:uppercase;margin-bottom:.75rem}
.oitem{display:flex;justify-content:space-between;align-items:center;padding:.4rem 0;border-bottom:1px solid rgba(255,255,255,.05);font-size:.88rem}
.oitem:last-child{border-bottom:none}
.oin{color:var(--tx2);max-width:68%;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.oip{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:1px;color:var(--a)}
.odiv{border:none;border-top:1px solid var(--br);margin:.75rem 0}
.otr{display:flex;justify-content:space-between;align-items:center}
.otl{font-family:'Share Tech Mono',monospace;font-size:.7rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase}
.otv{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:2px;color:var(--a2)}
/* payment method */
.pmg{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.5rem}
.pm{background:var(--bg2);border:2px solid var(--br);padding:1rem;cursor:pointer;transition:all .2s;text-align:center;position:relative}
.pm:hover{border-color:rgba(0,229,255,.3)}.pm.sel{border-color:var(--a);background:rgba(0,229,255,.05)}
.pm.sel::after{content:'✓';position:absolute;top:8px;right:10px;color:var(--a);font-family:'Share Tech Mono',monospace;font-size:.7rem}
.pmi{font-size:1.8rem;display:block;margin-bottom:.5rem}
.pmn{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;color:var(--tx)}
.pmd{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:1px;color:var(--tx2);margin-top:2px}
/* form */
.fg{margin-bottom:1rem}
.fl{font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase;display:block;margin-bottom:.5rem}
.fin{width:100%;background:var(--bg2);border:1px solid var(--br);color:var(--tx);font-family:'Rajdhani',sans-serif;font-size:1rem;padding:10px 14px;outline:none;transition:border-color .2s}
.fin:focus{border-color:var(--a)}
.fin::placeholder{color:rgba(138,153,187,.4)}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.fhint{font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:1px;color:var(--tx2);margin-top:.4rem}
.upiapps{display:flex;gap:.5rem;margin-top:.75rem;flex-wrap:wrap}
.uapp{background:var(--bg2);border:1px solid var(--br);padding:6px 14px;cursor:pointer;font-family:'Share Tech Mono',monospace;font-size:.62rem;letter-spacing:1px;color:var(--tx2);transition:all .2s;display:flex;align-items:center;gap:6px}
.uapp:hover,.uapp.sel{border-color:var(--a);color:var(--a);background:rgba(0,229,255,.05)}
.codbox{background:var(--bg2);border:1px solid rgba(255,184,0,.2);padding:1.2rem;margin-bottom:1rem}
.codtit{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:2px;color:#ffb800;margin-bottom:.5rem}
.codbox p{font-size:.88rem;color:var(--tx2);line-height:1.6}
.bkg{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;margin-bottom:1rem}
.bkb{background:var(--bg2);border:1px solid var(--br);padding:.75rem .5rem;cursor:pointer;transition:all .2s;text-align:center;font-family:'Share Tech Mono',monospace;font-size:.6rem;letter-spacing:1px;color:var(--tx2);text-transform:uppercase}
.bkb:hover,.bkb.sel{border-color:var(--a);color:var(--a);background:rgba(0,229,255,.05)}
.paynow{width:100%;background:var(--a2);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:1.3rem;letter-spacing:4px;padding:18px;border:none;cursor:pointer;text-transform:uppercase;transition:all .2s;clip-path:polygon(0 0,calc(100% - 12px) 0,100% 12px,100% 100%,12px 100%,0 calc(100% - 12px));margin-top:.75rem}
.paynow:hover{box-shadow:var(--glow2);transform:translateY(-1px)}
.secbdg{display:flex;align-items:center;justify-content:center;gap:6px;margin-top:.75rem;font-family:'Share Tech Mono',monospace;font-size:.62rem;letter-spacing:2px;color:var(--tx2)}
/* success */
.succ{text-align:center;padding:2rem 1rem}
.sico2{font-size:4rem;display:block;margin-bottom:1rem;animation:popin .4s cubic-bezier(.22,1,.36,1) both}
.stit{font-family:'Bebas Neue',sans-serif;font-size:2.5rem;letter-spacing:3px;color:var(--a);margin-bottom:.5rem}
.ssub{font-size:1rem;color:var(--tx2);margin-bottom:2rem;line-height:1.6}
.sdet{background:var(--bg2);border:1px solid var(--br);padding:1rem;margin-bottom:1.5rem;text-align:left}
.sdr{display:flex;justify-content:space-between;padding:.4rem 0;font-size:.88rem;border-bottom:1px solid rgba(255,255,255,.05)}
.sdr:last-child{border-bottom:none}
.sdl{color:var(--tx2);font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:1px;text-transform:uppercase}
.sdv{color:var(--tx);font-weight:600}
@keyframes popin{from{transform:scale(0) rotate(-10deg)}to{transform:scale(1) rotate(0)}}
/* TOAST */
.toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(100px);background:var(--surf2);border:1px solid var(--a);color:var(--a);font-family:'Share Tech Mono',monospace;font-size:.75rem;letter-spacing:2px;padding:12px 24px;z-index:2000;transition:transform .3s;white-space:nowrap;box-shadow:var(--glow)}
.toast.show{transform:translateX(-50%) translateY(0)}
/* FOOTER */
footer{position:relative;z-index:1;background:var(--bg2);border-top:1px solid var(--br);padding:4rem 5vw 2rem}
.fg2{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem;margin-bottom:3rem}
.fbrand p{font-size:.9rem;color:var(--tx2);line-height:1.7;margin:.75rem 0 1.5rem}
.slinks{display:flex;gap:.75rem}
.sla{width:36px;height:36px;border:1px solid var(--br);display:flex;align-items:center;justify-content:center;font-size:.85rem;text-decoration:none;color:var(--tx2);transition:all .2s}
.sla:hover{border-color:var(--a);color:var(--a);box-shadow:var(--glow)}
.fc h4{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:3px;color:var(--tx);margin-bottom:1.2rem}
.fc ul{list-style:none;display:flex;flex-direction:column;gap:.6rem}
.fc a{font-size:.85rem;color:var(--tx2);text-decoration:none;transition:color .2s;cursor:pointer}
.fc a:hover{color:var(--a)}
.fbot{border-top:1px solid var(--br);padding-top:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem}
.fbot p{font-family:'Share Tech Mono',monospace;font-size:.65rem;letter-spacing:2px;color:var(--tx2);text-transform:uppercase}
.pics{display:flex;gap:.5rem}
.pic{background:var(--surf);border:1px solid var(--br);padding:4px 8px;font-family:'Share Tech Mono',monospace;font-size:.6rem;color:var(--tx2)}
/* ── LOGIN BUTTON & USER AVATAR ── */
.login-btn{background:transparent;border:1px solid rgba(255,255,255,.18);color:var(--tx2);font-family:'Share Tech Mono',monospace;font-size:.72rem;letter-spacing:2px;padding:8px 16px;cursor:pointer;text-transform:uppercase;transition:all .2s;white-space:nowrap}
.login-btn:hover{border-color:var(--a);color:var(--a)}
.user-pill{display:flex;align-items:center;gap:8px;cursor:pointer;background:transparent;border:1px solid var(--br);padding:5px 12px 5px 5px;transition:all .2s;position:relative}
.user-pill:hover{border-color:var(--a)}
.user-av{width:28px;height:28px;border-radius:50%;object-fit:cover;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:#fff;flex-shrink:0}
.user-name{font-family:'Share Tech Mono',monospace;font-size:.68rem;letter-spacing:1px;color:var(--tx);max-width:90px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
/* dropdown */
.user-menu{position:absolute;top:calc(100% + 8px);right:0;background:var(--surf);border:1px solid var(--br);min-width:180px;z-index:300;box-shadow:0 16px 40px rgba(0,0,0,.5);display:none}
.user-pill:hover .user-menu,.user-pill:focus-within .user-menu{display:block}
.user-menu-item{display:flex;align-items:center;gap:10px;padding:.75rem 1rem;font-family:'Share Tech Mono',monospace;font-size:.68rem;letter-spacing:1px;color:var(--tx2);cursor:pointer;text-transform:uppercase;transition:all .2s;border-bottom:1px solid var(--br)}
.user-menu-item:last-child{border-bottom:none}
.user-menu-item:hover{background:rgba(0,229,255,.05);color:var(--a)}
.user-menu-item.logout{color:var(--a2)}.user-menu-item.logout:hover{background:rgba(255,45,120,.05);color:var(--a2)}

/* ── AUTH FULL-PAGE OVERLAY ── */
.auth-ovl{position:fixed;inset:0;z-index:1200;display:none;align-items:center;justify-content:center}
.auth-ovl.open{display:flex}
.auth-backdrop{position:absolute;inset:0;background:rgba(2,4,14,.96);backdrop-filter:blur(20px)}
/* particles */
.auth-particles{position:absolute;inset:0;overflow:hidden;pointer-events:none}
.auth-particle{position:absolute;border-radius:50%;animation:pfloat linear infinite;opacity:0}
@keyframes pfloat{0%{transform:translateY(100vh) scale(0);opacity:0}10%{opacity:.6}90%{opacity:.3}100%{transform:translateY(-20vh) scale(1);opacity:0}}
/* card */
.auth-card{position:relative;z-index:1;width:min(480px,95vw);animation:authIn .45s cubic-bezier(.22,1,.36,1) both}
@keyframes authIn{from{opacity:0;transform:translateY(40px) scale(.96)}to{opacity:1;transform:none}}
.auth-top{text-align:center;padding:2.5rem 2.5rem 0}
.auth-logo{display:flex;align-items:center;justify-content:center;gap:10px;margin-bottom:.5rem}
.auth-logo-mark{width:32px;height:32px;filter:drop-shadow(0 0 6px rgba(139,92,246,.9))}
.auth-logo-text{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:5px;background:linear-gradient(90deg,#a78bfa,#00e5ff,#ff2d78);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.auth-logo span{color:var(--a2)}
.auth-tagline{font-family:'Share Tech Mono',monospace;font-size:.62rem;letter-spacing:3px;color:var(--tx2);text-transform:uppercase;margin-bottom:2rem}
.auth-tabs{display:flex;border-bottom:1px solid var(--br);margin:0 2.5rem}
.auth-tab{flex:1;font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:3px;padding:.75rem;background:none;border:none;color:var(--tx2);cursor:pointer;text-transform:uppercase;transition:color .2s;position:relative}
.auth-tab.active{color:var(--a)}
.auth-tab.active::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:2px;background:var(--a);box-shadow:0 0 8px var(--a)}
.auth-body{padding:2rem 2.5rem 2.5rem;background:var(--surf);border:1px solid var(--br);border-top:none;margin:0 0 0 0}
/* social buttons */
.social-auth-btn{width:100%;display:flex;align-items:center;gap:12px;padding:13px 18px;background:var(--bg2);border:1px solid var(--br);color:var(--tx);font-family:'Rajdhani',sans-serif;font-size:1rem;font-weight:600;cursor:pointer;transition:all .25s;margin-bottom:.75rem;text-align:left;position:relative;overflow:hidden}
.social-auth-btn::before{content:'';position:absolute;inset:0;opacity:0;transition:opacity .25s}
.social-auth-btn:hover{transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,0,0,.3)}
.social-auth-btn:hover::before{opacity:1}
.google-btn{border-color:rgba(66,133,244,.3)}
.google-btn::before{background:linear-gradient(135deg,rgba(66,133,244,.08),rgba(234,67,53,.05))}
.google-btn:hover{border-color:rgba(66,133,244,.6);box-shadow:0 8px 24px rgba(66,133,244,.15)}
.outlook-btn{border-color:rgba(0,120,212,.3)}
.outlook-btn::before{background:linear-gradient(135deg,rgba(0,120,212,.08),rgba(0,188,242,.05))}
